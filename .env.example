# Supabase Database Configuration
# You can find these values in your Supabase project settings under "API".
# Create a .env file and add these variables to connect your database.

VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# EmailJS Configuration
# Sign up at emailjs.com, create an email service and two templates (Registration, Booking).
# The Admin Email receives these notifications.
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID_REGISTER=
VITE_EMAILJS_TEMPLATE_ID_BOOKING=
VITE_EMAILJS_PUBLIC_KEY=
VITE_ADMIN_EMAIL=consultsjet@gmail.com
VITE_ADMIN_PASSWORD=admin123

# WhatsApp Configuration
# VITE_WHATSAPP_NUMBER should be the full number including country code, no "+" or spaces (e.g., 2347060734773)
# VITE_WHATSAPP_DISPLAY_NUMBER is the formatted number shown to users (e.g., 07060734773)
VITE_WHATSAPP_NUMBER=2347060734773
VITE_WHATSAPP_DISPLAY_NUMBER=07060734773

# AI Support (Optional)
GEMINI_API_KEY=
